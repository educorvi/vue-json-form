# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=form_builder
DB_PASSWORD=form_builder
DB_NAME=form_builder

# Set to 'development' to enable TypeORM query logging
NODE_ENV=development

# Keycloak OIDC — configure to match your Keycloak realm settings
NUXT_OAUTH_KEYCLOAK_CLIENT_ID=vueformbuilder
NUXT_OAUTH_KEYCLOAK_CLIENT_SECRET=your-client-secret
NUXT_OAUTH_KEYCLOAK_SERVER_URL=http://localhost:8080
NUXT_OAUTH_KEYCLOAK_REALM=dev

# Session encryption key — must be at least 32 characters (auto-generated in dev)
NUXT_SESSION_PASSWORD=a-random-password-with-at-least-32-characters
