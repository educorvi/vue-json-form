{
    "name": "vue-json-form",
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.23.0",
        "@size-limit/file": "^12.0.1",
        "@size-limit/preset-big-lib": "^12.0.1",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@yarnpkg/types": "^4.0.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unused-imports": "^4.3.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "mkdirp": "^3.0.1",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "semantic-release": "^25.0.3",
        "semantic-release-monorepo": "^8.0.2",
        "semantic-release-yarn": "^3.0.2",
        "semver": "^7.7.4",
        "size-limit": "^12.0.1",
        "syncpack": "^14.2.1",
        "turbo": "^2.8.20",
        "typedoc": "^0.28.18",
        "vue-eslint-parser": "^10.4.0"
    },
    "packageManager": "yarn@4.13.0",
    "private": true,
    "scripts": {
        "build": "turbo check-types build:internal",
        "build:demo": "turbo run check-types build:internal --filter demo",
        "build:schemas": "turbo run check-types build:internal --filter @educorvi/vue-json-form-schemas",
        "build:vue-json-form": "turbo run check-types build:internal --filter @educorvi/vue-json-form",
        "build:webcomponent": "turbo run check-types build:internal --filter @educorvi/vue-json-form-webcomponent",
        "commitlint": "commitlint --edit",
        "doc": "turbo doc:root && echo 'Copying files...' && run-p -l \"doc:copy:**\"",
        "doc:copy:demo": "rimraf ./docs/demo && mkdirp ./docs/demo && cp -r ./apps/demo/dist/* ./docs/demo",
        "doc:copy:ui": "rimraf ./docs/ui-schema && mkdirp ./docs/ui-schema && cp -r ./packages/schemas/docs-dist/* ./docs/ui-schema",
        "doc:copy:ui-schema-files": "rimraf ./docs/schemas && cp -r ./packages/schemas/src/ui ./docs/schemas",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "pre-commit": "yarn run doc && yarn workspaces foreach run pre-commit",
        "prepare": "husky",
        "publish": "yarn workspaces foreach --topological-dev -Av --no-private --exclude . npm publish --access public --tolerate-republish",
        "release": "yarn workspaces foreach --topological-dev -Av --exclude . run semantic-release -e semantic-release-monorepo",
        "release:dry-run": "yarn workspaces foreach --topological-dev -Av --exclude . run semantic-release --dry-run -e semantic-release-monorepo",
        "setOldVersions": "yarn workspaces foreach -Apv --exclude . exec $(git rev-parse --show-toplevel)/.github/findAndSetOldVersion.mjs",
        "size": "size-limit",
        "test": "turbo run test:all",
        "test:unit": "turbo run test:unit",
        "test:e2e": "turbo run test:e2e"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
