{
    "name": "@educorvi/vue-json-form-builder",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:internal": "vite -c vite.config.ts --host",
        "dev": "turbo watch dev:internal",
        "build": "turbo build:internal check-types",
        "build:internal": "vue-tsc --noEmit && vite build",
        "check-types": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "preview": "vite preview",
        "test:unit": "vitest --run",
        "test:watch": "vitest",
        "format": "yarn run -T prettier --write src/",
        "format:check": "yarn run -T prettier --check src/",
        "lint": "yarn run -T eslint .",
        "lint:fix": "yarn run -T eslint . --fix",
        "prepack": "yarn run build"
    },
    "dependencies": {
        "@educorvi/vue-json-form": "workspace:^",
        "@educorvi/vue-json-form-ajv-validator": "workspace:^",
        "@popperjs/core": "^2.11.8",
        "@vueuse/core": "^14.3.0",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "bootstrap-vue-next": "0.45.5",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "uuid": "^14.0.0",
        "vue": "^3.5.35",
        "vue-draggable-plus": "^0.6.1",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@semantic-release/exec": "^7.1.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "prettier": "^3.8.3",
        "sass-embedded": "^1.100.0",
        "semantic-release": "^25.0.3",
        "semantic-release-monorepo": "^8.0.2",
        "semantic-release-yarn": "^3.0.2",
        "turbo": "^2.9.18",
        "typescript": "~6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.4"
    }
}
