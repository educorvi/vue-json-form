    "exports": {
        ".": {
            "types": "./dist/vue-json-form.d.ts",
            "import": "./dist/vue-json-form.js",
            "default": "./dist/vue-json-form.js"
        },
        "./dist/*": "./dist/*",
        "./src/exampleSchemas/*": "./src/exampleSchemas/*"
    },
    "files": [
        "dist",
        "src/exampleSchemas",
        "package.json",
        "README.md"
    ],
    "license": "MIT",
    "main": "dist/vue-json-form.cjs",
    "module": "dist/vue-json-form.js",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/educorvi/vue-json-form.git",
        "directory": "packages/vue-json-form"
    },
    "scripts": {
        "build": "turbo build:internal check-types",
        "build:internal": "vite build",
        "check-types": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "dev:internal": "vite -c vite.dev.config.ts --host",
        "dev": "turbo watch dev:internal",
        "format": "yarn run -T prettier --write src/",
        "lint": "yarn run -T eslint .",
        "lint:fix": "yarn run -T eslint . --fix",
        "pre-commit": "echo ''",
        "prepack": "yarn run build",
        "prepare": "husky",
        "preview": "vite preview",
        "release:alpha": "yarn npm publish --access public --tag alpha",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:unit": "vitest --run"
    },
    "type": "module",
    "types": "dist/vue-json-form.d.ts"
}
