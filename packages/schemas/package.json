{
    "name": "@educorvi/vue-json-form-schemas",
    "description": "Schemas for Vue JSON Form",
    "version": "0.0.0",
    "dependencies": {
        "@educorvi/rita": "^5.5.1",
        "json-schema-typed": "^8.0.2"
    },
    "devDependencies": {
        "@apidevtools/json-schema-ref-parser": "^15.3.3",
        "@semantic-release/exec": "^7.1.0",
        "json-schema-to-typescript": "^15.0.4",
        "mkdirp": "^3.0.1",
        "npm-run-all": "^4.1.5",
        "rimraf": "^6.1.3",
        "rollup-plugin-copy": "^3.5.0",
        "semantic-release": "^25.0.3",
        "semantic-release-monorepo": "^8.0.2",
        "semantic-release-yarn": "^3.0.2",
        "turbo": "^2.8.20",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-externalize-deps": "^0.10.0",
        "vite-plugin-static-copy": "^3.3.0"
    },
    "exports": {
        ".": {
            "types": "./dist/vue-json-form-schemas.d.ts",
            "import": "./dist/vue-json-form-schemas.js",
            "require": "./dist/vue-json-form-schemas.cjs",
            "default": "./dist/vue-json-form-schemas.js"
        },
        "./dist/ui.schema.json": "./dist/ui.schema.json",
        "./dist/json-2019.schema.json": "./dist/json-2019.schema.json",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "./dist/vue-json-form-schemas.cjs",
    "module": "./dist/vue-json-form-schemas.js",
    "packageManager": "yarn@4.4.0",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/educorvi/vue-json-form.git",
        "directory": "packages/schemas"
    },
    "scripts": {
        "build": "turbo build:internal check-types",
        "build:internal": "vite build",
        "check-types": "tsc --noEmit",
        "doc": "rimraf ./docs-dist && mkdirp ./docs-dist && generate-schema-doc ./src/generated/ui-merged.schema.json ./docs-dist/index.html",
        "generateTypings": "run-p 'generateTypings:*'",
        "generateTypings:uiSchema": "mkdirp src/generated && cd src/ui/ && json2ts -i ui.schema.json -o ../generated/ui-schema.d.ts",
        "lint": "yarn run -T eslint .",
        "lint:fix": "yarn run -T eslint . --fix",
        "mergeSchema": "node mergeSchema.cjs",
        "prepack": "yarn run build"
    },
    "type": "module",
    "types": "./dist/vue-json-form-schemas.d.ts",
    "sideEffects": false
}
