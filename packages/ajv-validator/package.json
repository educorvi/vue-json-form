{
    "name": "@educorvi/vue-json-form-ajv-validator",
    "description": "ajv-validator for Vue JSON Form",
    "version": "0.0.0",
    "dependencies": {
        "@educorvi/vue-json-form-schemas": "workspace:^",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1"
    },
    "devDependencies": {
        "@semantic-release/exec": "^7.1.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.2",
        "npm-run-all": "^4.1.5",
        "rollup-plugin-copy": "^3.5.0",
        "semantic-release": "^25.0.3",
        "semantic-release-monorepo": "^8.0.2",
        "semantic-release-yarn": "^3.0.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "turbo": "^2.9.0",
        "typescript": "~6.0.2",
        "vite": "^8.0.3",
        "vite-bundle-analyzer": "^1.3.6",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-static-copy": "^4.0.0",
        "vitest": "^4.1.2"
    },
    "exports": {
        ".": {
            "types": "./dist/vue-json-form-ajv-validator.d.ts",
            "import": "./dist/vue-json-form-ajv-validator.js",
            "require": "./dist/vue-json-form-ajv-validator.cjs",
            "default": "./dist/vue-json-form-ajv-validator.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "./dist/vue-json-form-ajv-validator.cjs",
    "module": "./dist/vue-json-form-ajv-validator.js",
    "packageManager": "yarn@4.4.0",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/educorvi/vue-json-form.git",
        "directory": "packages/ajv-validator"
    },
    "scripts": {
        "build": "turbo build:internal check-types",
        "build:ajvStandalone": "tsx src/buildStandaloneAjv.ts",
        "build:internal": "yarn run build:ajvStandalone && vite build",
        "check-types": "tsc --noEmit",
        "lint": "yarn run -T eslint .",
        "lint:fix": "yarn run -T eslint . --fix",
        "prepack": "yarn run build",
        "test:unit": "vitest --run"
    },
    "type": "module",
    "types": "./dist/vue-json-form-ajv-validator.d.ts",
    "sideEffects": false
}
