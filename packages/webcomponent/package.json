{
    "name": "@educorvi/vue-json-form-webcomponent",
    "description": "Vue JSON Form Webcomponent",
    "version": "0.0.0",
    "dependencies": {
        "@educorvi/vue-json-form": "workspace:^",
        "@educorvi/vue-json-form-ajv-validator": "workspace:^",
        "@vueuse/core": "^14.3.0",
        "axios": "^1.16.1",
        "bootstrap-vue-next": "0.45.4",
        "js-cookie": "^3.0.7",
        "unplugin-icons": "^23.0.1",
        "vue": "^3.5.34",
        "vue-markdown-render": "^2.3.0"
    },
    "devDependencies": {
        "@iconify-json/bi": "^1.2.7",
        "@playwright/test": "^1.59.1",
        "@semantic-release/exec": "^7.1.0",
        "@tsconfig/node18": "^18.2.6",
        "@types/bootstrap": "^5",
        "@types/busboy": "^1",
        "@types/js-cookie": "^3",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.6.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/ui": "^4.1.5",
        "@vue/tsconfig": "^0.9.1",
        "bootstrap": "^5.3.8",
        "busboy": "^1.6.0",
        "jsdom": "^29.1.0",
        "npm-run-all": "^4.1.5",
        "pdf-lib": "^1.17.1",
        "sass-embedded": "^1.99.0",
        "semantic-release": "^25.0.3",
        "semantic-release-monorepo": "^8.0.2",
        "semantic-release-yarn": "^3.0.2",
        "terser": "^5.46.2",
        "turbo": "^2.9.10",
        "typescript": "~6.0.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.7"
    },
    "exports": {
        ".": {
            "import": "./dist/default/vue-json-form.mjs",
            "require": "./dist/default/vue-json-form.umd.js"
        },
        "./shadowDom": {
            "import": "./dist/shadowDom/vue-json-form.mjs",
            "require": "./dist/shadowDom/vue-json-form.umd.js"
        },
        "./ajvValidator": {
            "import": "./dist/ajvValidator/vue-json-form.mjs",
            "require": "./dist/ajvValidator/vue-json-form.umd.js"
        },
        "./vue-json-form.css": "./dist/default/vue-json-form.css"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "dist/default/vue-json-form.umd.js",
    "module": "dist/default/vue-json-form.mjs",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/educorvi/vue-json-form.git",
        "directory": "packages/webcomponent"
    },
    "scripts": {
        "build": "turbo build:internal check-types",
        "build:internal": "run-p 'build:internal:*'",
        "build:internal:ajvValidator": "BUILD_TARGET=ajvValidator vite build",
        "build:internal:default": "BUILD_TARGET=default vite build",
        "build:internal:shadowDom": "BUILD_TARGET=shadowDom vite build",
        "check-types": "vue-tsc --noEmit",
        "dev:internal": "vite -c vite.dev.config.ts --host",
        "dev": "turbo watch dev:internal",
        "lint": "yarn run -T eslint .",
        "lint:fix": "yarn run -T eslint . --fix",
        "prepack": "yarn run build",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:unit": "vitest --run",
        "test:unit:ui": "vitest --ui"
    },
    "type": "commonjs"
}
